<UserControl x:Class="ResourceRouter.App.Views.DropPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280"
             Height="182">
    <UserControl.Resources>
        <Style x:Key="DropZoneButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FF1B2430" />
            <Setter Property="Foreground" Value="#FFE7EDF4" />
            <Setter Property="BorderBrush" Value="#FF4B5868" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ZoneBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ZoneBorder" Property="Background" Value="#FF243140" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ZoneBorder" Property="Background" Value="#FF2D3F53" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PublicZoneButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DropZoneButtonStyle}">
            <Setter Property="Background" Value="#FF1A2C28" />
            <Setter Property="BorderBrush" Value="#FF3B9278" />
        </Style>

        <Style x:Key="PrivateZoneButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DropZoneButtonStyle}">
            <Setter Property="Background" Value="#FF1A2336" />
            <Setter Property="BorderBrush" Value="#FF6C7EA3" />
        </Style>
    </UserControl.Resources>

        <Grid Margin="4"
            AllowDrop="True"
            DragOver="OnPanelDragOver"
            DragLeave="OnPanelDragLeave">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="ZoneGrid" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="PublicFocusHalo"
                    Grid.Column="0"
                    Margin="4"
                    CornerRadius="11"
                    Background="#FF285D4E"
                    BorderBrush="#FF74C8AF"
                    BorderThickness="1"
                    Opacity="0.16"
                    IsHitTestVisible="False" />

            <Border x:Name="PrivateFocusHalo"
                    Grid.Column="1"
                    Margin="4"
                    CornerRadius="11"
                    Background="#FF334A71"
                    BorderBrush="#FF8CB1DD"
                    BorderThickness="1"
                    Opacity="0.16"
                    IsHitTestVisible="False" />

            <Button x:Name="PublicZoneButton"
                    Grid.Column="0"
                    Style="{StaticResource PublicZoneButtonStyle}"
                    AllowDrop="True"
                    DragOver="OnPublicDragOver"
                    Drop="OnPublicDrop"
                    MouseEnter="OnPublicMouseEnter"
                    MouseLeave="OnZoneMouseLeave"
                    Click="OnPublicClick"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform x:Name="PublicButtonScale" ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" FontSize="15" Text="公开" />
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#FFB5D9CD" Text="云端处理 / 默认同步" />
                </StackPanel>
            </Button>

            <Button x:Name="PrivateZoneButton"
                    Grid.Column="1"
                    Style="{StaticResource PrivateZoneButtonStyle}"
                    AllowDrop="True"
                    DragOver="OnPrivateDragOver"
                    Drop="OnPrivateDrop"
                    MouseEnter="OnPrivateMouseEnter"
                    MouseLeave="OnZoneMouseLeave"
                    Click="OnPrivateClick"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform x:Name="PrivateButtonScale" ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" FontSize="15" Text="隐私" />
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#FFC3CFE5" Text="仅本地处理 / 不同步" />
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock x:Name="PendingHintText"
                   Grid.Row="1"
                   Margin="6,10,6,0"
                   Foreground="#FF9AA8B8"
                   FontSize="11"
                   Text="拖入后可点击公开/隐私确认处理"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
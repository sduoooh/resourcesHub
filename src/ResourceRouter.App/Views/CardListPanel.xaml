<UserControl x:Class="ResourceRouter.App.Views.CardListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ResourceRouter.App.Views"
             Width="400">
    <UserControl.Resources>
        <Style x:Key="SearchInputStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFE6ECF2" />
            <Setter Property="CaretBrush" Value="#FFE6ECF2" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF243141" />
            <Setter Property="Foreground" Value="#FFDFE8F2" />
            <Setter Property="BorderBrush" Value="#FF5C718B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF2F4156" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF86A4C6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF415A76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TagChipToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,2,6,2" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Background" Value="#FF23303D" />
            <Setter Property="Foreground" Value="#FFB8C6D7" />
            <Setter Property="BorderBrush" Value="#FF4F6073" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="TagBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FF87A4C6" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TagBorder" Property="Background" Value="#FF2D6B5B" />
                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FF7FD3BE" />
                                <Setter Property="Foreground" Value="#FFE9F7F3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8" PreviewMouseLeftButtonDown="OnRootPreviewMouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,8,0,8">
            <Border x:Name="SearchContainer"
                Height="28"
                    Margin="6,0,6,0"
                    Background="#FF1B2430"
                    BorderBrush="#FF4D5C70"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource SearchInputStyle}"
                         TextChanged="OnSearchBoxTextChanged"
                         ToolTip="搜索资源（支持 #tag 或 tag:xxx）" />
            </Border>
        </Grid>

        <Border x:Name="TagChipsContainer"
            Grid.Row="1"
            Margin="6,2,6,8"
                Background="#FF151D25"
                BorderBrush="#FF334252"
                BorderThickness="1"
                CornerRadius="8"
            Padding="6,4"
            Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          PanningMode="HorizontalOnly">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Height" Value="4" />
                        <Setter Property="Margin" Value="0,2,0,0" />
                        <Setter Property="Background" Value="#FF0E141B" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <Track x:Name="PART_Track">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" IsTabStop="False" />
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="ThumbChrome"
                                                                    Margin="1"
                                                                    CornerRadius="3"
                                                                    Background="#FF536274"
                                                                    BorderBrush="#FF6A7C92"
                                                                    BorderThickness="1" />
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ThumbChrome" Property="Background" Value="#FF6C7F96" />
                                                                    <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#FF8EA8C8" />
                                                                </Trigger>
                                                                <Trigger Property="IsDragging" Value="True">
                                                                    <Setter TargetName="ThumbChrome" Property="Background" Value="#FF86A2C4" />
                                                                    <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#FFAAC8EB" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" IsTabStop="False" />
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Resources>

                <StackPanel x:Name="TagChipsHost" Orientation="Horizontal" />
            </ScrollViewer>
        </Border>

                <ScrollViewer x:Name="CardsScrollViewer"
                                            Grid.Row="2"
                                            Background="#FF12171C"
                      BorderBrush="#FF303D4A"
                      BorderThickness="1"
                                            Margin="6,0,6,0"
                                            Padding="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                                            ScrollChanged="OnCardsScrollViewerScrollChanged"
                      PanningMode="VerticalOnly">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                                        <Setter Property="Width" Value="3" />
                                        <Setter Property="Margin" Value="0,6,2,6" />
                    <Setter Property="Background" Value="#FF0E141B" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbChrome"
                                                                Margin="1"
                                                                CornerRadius="4"
                                                                Background="#FF536274"
                                                                BorderBrush="#FF6A7C92"
                                                                BorderThickness="1" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbChrome" Property="Background" Value="#FF6C7F96" />
                                                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#FF8EA8C8" />
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbChrome" Property="Background" Value="#FF86A2C4" />
                                                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#FFAAC8EB" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Resources>

            <StackPanel x:Name="CardsHost" Margin="0" />
        </ScrollViewer>
    </Grid>
</UserControl>
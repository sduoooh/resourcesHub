<Window x:Class="ResourceRouter.App.Views.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:ResourceRouter.Core.Models;assembly=ResourceRouter.Core"
        Title="编辑处理配置"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="预设" />
        <ComboBox x:Name="PresetCombo" Grid.Row="1" Margin="0,4,0,8" Height="30" SelectionChanged="OnPresetChanged" />

        <TextBlock Grid.Row="2" Text="隐私级别" />
        <ComboBox x:Name="PrivacyCombo" Grid.Row="3" Margin="0,4,0,8" Height="30" />

        <TextBlock Grid.Row="4" Text="同步策略" />
        <ComboBox x:Name="SyncCombo" Grid.Row="5" Margin="0,4,0,8" Height="30" />

        <TextBlock Grid.Row="6" Text="处理模型" />
        <ComboBox x:Name="ModelCombo" Grid.Row="7" Margin="0,4,0,8" Height="30" />

        <StackPanel Grid.Row="8" Orientation="Vertical">
            <TextBlock Text="别名（可选）" />
            <TextBox x:Name="TitleBox" Margin="0,4,0,8" Height="28" MaxLength="{x:Static models:ResourceFieldLimits.AliasMaxLength}" />
            <TextBlock Text="备注（可选）" />
            <TextBox x:Name="NotesBox" Margin="0,4,0,8" Height="56" AcceptsReturn="True" TextWrapping="Wrap" />
            <TextBlock Text="属性标签（逗号分隔）" />
            <TextBox x:Name="TagsBox" Margin="0,4,0,0" Height="28" />
        </StackPanel>

        <StackPanel Grid.Row="9" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="0,0,8,0" Width="88" Height="30" IsCancel="True">取消</Button>
            <Button Width="88" Height="30" IsDefault="True" Click="OnConfirmClick">确认处理</Button>
        </StackPanel>
    </Grid>
</Window>
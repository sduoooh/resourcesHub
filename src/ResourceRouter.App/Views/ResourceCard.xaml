<UserControl x:Class="ResourceRouter.App.Views.ResourceCard"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ResourceRouter.Core.Models;assembly=ResourceRouter.Core"
             PreviewMouseMove="OnRootPreviewMouseMove"
             PreviewMouseLeftButtonUp="OnRootPreviewMouseLeftButtonUp"
             MinHeight="92"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <Style x:Key="HoverActionSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#66121A24" />
            <Setter Property="BorderBrush" Value="#FF607995" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CC243449" />
                    <Setter Property="BorderBrush" Value="#FFA4C3E5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProcessedActionSurfaceStyle" TargetType="Border" BasedOn="{StaticResource HoverActionSurfaceStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsProcessedRouteLocked, ElementName=Root}" Value="True">
                    <Setter Property="Background" Value="#66212A35" />
                    <Setter Property="BorderBrush" Value="#FF4A5562" />
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.68" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="#FFB43737" />
            <Setter Property="Foreground" Value="#FFFFF4F4" />
            <Setter Property="BorderBrush" Value="#FFF7AAAA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DeleteButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DeleteButtonChrome" Property="Background" Value="#FFC94A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DeleteButtonChrome" Property="Background" Value="#FFA13030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FF15202B" />
            <Setter Property="Background" Value="#FFEAF0F5" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FFD7E7F5" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFC6DCF2" />
                    <Setter Property="Foreground" Value="#FF0F1923" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InlineComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFE4E9EF" />
            <Setter Property="Foreground" Value="#FF15202B" />
            <Setter Property="BorderBrush" Value="#FF5E6977" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,0,6,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource InlineComboItemStyle}" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                CornerRadius="8"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>

                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="8,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}" />

                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="#FF556475"
                                                      StrokeThickness="1.4"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#FF7E94AB" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#FFEAF0F5"
                                        BorderBrush="#FF5E6977"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,2,0,0">
                                    <ScrollViewer CanContentScroll="True" MaxHeight="260">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="#FF5F8AB8" />
                                </Trigger>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="PART_Popup" Property="MinHeight" Value="32" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="DropDownToggle" Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineTagTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFE4E9EF" />
            <Setter Property="Foreground" Value="#FF15202B" />
            <Setter Property="BorderBrush" Value="#FF5E6977" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#FF5F8AB8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#FF7E94AB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineTagButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF243141" />
            <Setter Property="Foreground" Value="#FFDFE8F2" />
            <Setter Property="BorderBrush" Value="#FF5C718B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TagActionButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TagActionButtonBorder" Property="Background" Value="#FF2F4156" />
                                <Setter TargetName="TagActionButtonBorder" Property="BorderBrush" Value="#FF86A4C6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TagActionButtonBorder" Property="Background" Value="#FF415A76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineSectionExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="Transparent">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              Background="#FF2A3644"
                                              BorderBrush="#FF5B6F86"
                                              BorderThickness="1"
                                              Height="24"
                                              Padding="8,0"
                                              Cursor="Hand"
                                              Foreground="#FFD2DEEA"
                                              FontSize="11"
                                              FontWeight="SemiBold"
                                              Content="{TemplateBinding Header}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="9"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <TextBlock Text="{TemplateBinding Content}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{TemplateBinding Foreground}" />
                                                    <TextBlock x:Name="HeaderGlyph"
                                                               Text="▸"
                                                               FontSize="10"
                                                               Foreground="#FF9EB2C8"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,2,0" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderBorder" Property="Background" Value="#FF334354" />
                                                    <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#FF85A2C4" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="HeaderGlyph" Property="Text" Value="▾" />
                                                    <Setter TargetName="HeaderBorder" Property="Background" Value="#FF2F3E4F" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter x:Name="ExpandSite"
                                                  ContentSource="Content"
                                                  Margin="0,6,0,0"
                                                  Visibility="Collapsed"
                                                  Opacity="0"
                                                  RenderTransformOrigin="0.5,0">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform ScaleY="0.98" />
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ExpandSite" Property="Opacity" Value="1" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ExpandSite"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="0:0:0.14"
                                                             FillBehavior="Stop" />
                                            <DoubleAnimation Storyboard.TargetName="ExpandSite"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             From="0.98"
                                                             To="1"
                                                             Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ExpandSite" Property="Opacity" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineTagChipToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,2,6,2" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Background" Value="#FF23303D" />
            <Setter Property="Foreground" Value="#FFB8C6D7" />
            <Setter Property="BorderBrush" Value="#FF4F6073" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="TagBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FF87A4C6" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TagBorder" Property="Background" Value="#FF2D6B5B" />
                                <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FF7FD3BE" />
                                <Setter Property="Foreground" Value="#FFE9F7F3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ClipToBounds="False">
                <Border x:Name="DeleteRevealPanel"
                    Margin="6,6,6,0"
                    Width="106"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    Opacity="1"
                    IsHitTestVisible="False">
                <Grid>
                    <Button x:Name="DeleteCollectionButton"
                            Margin="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Style="{StaticResource DeleteActionButtonStyle}"
                            Content="删除集纳"
                            Click="OnDeleteCollectionClick">
                        <Button.RenderTransform>
                            <TranslateTransform X="4" />
                        </Button.RenderTransform>
                    </Button>
                </Grid>
            </Border>

                <Border x:Name="CardChrome"
                    Margin="6,6,6,0"
                    Padding="8,8"
                    BorderBrush="#FF354250"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="#FF1B2430"
                    PreviewMouseLeftButtonDown="OnCardPreviewMouseLeftButtonDown"
                    PreviewMouseMove="OnCardPreviewMouseMove"
                    PreviewMouseLeftButtonUp="OnCardPreviewMouseLeftButtonUp"
                    PreviewMouseRightButtonUp="OnCardPreviewMouseRightButtonUp">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="CardTranslate" X="0" />
                </Border.RenderTransform>
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FFE8EEF5"
                                       FontSize="13"
                                       Text="{Binding Resource.DisplayTitle, ElementName=Root}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#FFA7B6C7"
                                       FontSize="11"
                                       Visibility="{Binding DetailVisibility, ElementName=Root}"
                                       Text="{Binding StatusText, ElementName=Root}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      Visibility="{Binding DetailVisibility, ElementName=Root}"
                                      Margin="0,8,0,0"
                                      HorizontalAlignment="Right">
                            <ItemsControl ItemsSource="{Binding VisibleTags, ElementName=Root}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,0"
                                                Padding="8,2"
                                                Background="#FF213444"
                                                BorderBrush="#FF5D7892"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="10"
                                                       Foreground="#FFD3E2F4" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Border x:Name="HoverMask"
                            Background="#D9253445"
                            CornerRadius="7"
                            Opacity="0"
                            IsHitTestVisible="False" />

                    <Grid x:Name="HoverActions"
                          Opacity="0"
                          Visibility="Collapsed"
                          IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="3">
                            <Border x:Name="RawActionPlaceholder"
                                    BorderBrush="#FF98B5D4"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Background="#22233449"
                                    Visibility="Collapsed" />
                            <Border x:Name="RawActionSurface"
                                    Style="{StaticResource HoverActionSurfaceStyle}"
                                    PreviewMouseLeftButtonDown="OnRawActionMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="OnActionSurfaceMouseLeftButtonUp"
                                    MouseMove="OnActionSurfaceMouseMove">
                                <Border.RenderTransform>
                                    <TranslateTransform />
                                </Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="原始文件" FontWeight="SemiBold" Foreground="#FFF0F5FB" />
                                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#FFC8D6E8" Text="拖拽导出" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1" Margin="3">
                            <Border x:Name="ProcessedActionPlaceholder"
                                    BorderBrush="#FF98B5D4"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Background="#22233449"
                                    Visibility="Collapsed" />
                            <Border x:Name="ProcessedActionSurface"
                                    Style="{StaticResource ProcessedActionSurfaceStyle}"
                                    PreviewMouseLeftButtonDown="OnProcessedActionMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="OnActionSurfaceMouseLeftButtonUp"
                                    MouseMove="OnActionSurfaceMouseMove">
                                <Border.RenderTransform>
                                    <TranslateTransform />
                                </Border.RenderTransform>
                                <StackPanel>
                                    <TextBlock Text="处理结果" FontWeight="SemiBold" Foreground="#FFF0F5FB" />
                                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#FFC8D6E8" Text="{Binding ProcessedRouteSummary, ElementName=Root}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="InlineConfigHost"
                Grid.Row="1"
            Margin="6,0,6,8"
            Background="#FF1B2430"
            BorderBrush="#FF354250"
                BorderThickness="1"
            CornerRadius="10"
                Visibility="Collapsed"
                Opacity="0"
                PreviewMouseLeftButtonDown="OnInlineConfigHostPreviewMouseLeftButtonDown"
                PreviewMouseRightButtonUp="OnInlineConfigHostPreviewMouseRightButtonUp">
            <Border Margin="8"
                    Background="#FFD5DBE2"
                    BorderBrush="#FF9EA7B1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8,8,8,6">
                <StackPanel>
                    <Expander Header="基础"
                              IsExpanded="True"
                              Style="{StaticResource InlineSectionExpanderStyle}">
                        <Border Background="#FFE2E8EF"
                                BorderBrush="#FFA9B6C3"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,8,8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="预设" />
                                <ComboBox x:Name="InlinePresetCombo" Grid.Row="0" Grid.Column="1" Height="26" Margin="0,0,0,6" Style="{StaticResource InlineComboStyle}" SelectionChanged="OnInlinePresetChanged" DropDownClosed="OnInlineOptionDropDownClosed" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="隐私" />
                                <ComboBox x:Name="InlinePrivacyCombo" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,0,0,6" Style="{StaticResource InlineComboStyle}" SelectionChanged="OnInlineOptionChanged" DropDownClosed="OnInlineOptionDropDownClosed" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="同步" />
                                <ComboBox x:Name="InlineSyncCombo" Grid.Row="2" Grid.Column="1" Height="26" Margin="0,0,0,6" Style="{StaticResource InlineComboStyle}" SelectionChanged="OnInlineOptionChanged" DropDownClosed="OnInlineOptionDropDownClosed" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="别名" />
                                <TextBox x:Name="InlineTitleBox"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="0,0,0,6"
                                         MaxLength="{x:Static models:ResourceFieldLimits.AliasMaxLength}"
                                         Style="{StaticResource InlineTagTextBoxStyle}"
                                         TextChanged="OnInlineMetadataTextChanged" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Top" Foreground="#FF1F2A36" Text="注释" />
                                <TextBox x:Name="InlineAnnotationsBox"
                                         Grid.Row="4"
                                         Grid.Column="1"
                                         Margin="0,0,0,6"
                                         Height="56"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource InlineTagTextBoxStyle}"
                                         TextChanged="OnInlineMetadataTextChanged" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Top" Foreground="#FF1F2A36" Text="标签" />
                                <Border x:Name="InlineTagChipsContainer"
                                    Grid.Row="5"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        Background="#FFEAF0F5"
                                        BorderBrush="#FFA9B6C3"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="6,4">
                                    <ScrollViewer MaxHeight="88"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="False">
                                        <WrapPanel x:Name="InlineTagChipsHost" />
                                    </ScrollViewer>
                                </Border>

                                <TextBox x:Name="InlineTagSearchBox"
                                         Grid.Row="6"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Margin="0,0,0,6"
                                         MaxLength="{x:Static models:ResourceFieldLimits.TagMaxLength}"
                                         Style="{StaticResource InlineTagTextBoxStyle}"
                                         ToolTip="搜索已有标签"
                                         TextChanged="OnInlineTagSearchTextChanged" />

                                <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="InlineTagTypeToggleButton"
                                            Grid.Column="0"
                                            MinWidth="52"
                                            Margin="0,0,6,0"
                                            Style="{StaticResource InlineTagButtonStyle}"
                                            Content="属性"
                                            Click="OnInlineTagTypeToggleClick" />

                                    <TextBox x:Name="InlineTagInputBox"
                                             Grid.Column="1"
                                             Margin="0,0,6,0"
                                             MaxLength="{x:Static models:ResourceFieldLimits.TagMaxLength}"
                                             Style="{StaticResource InlineTagTextBoxStyle}"
                                             VerticalContentAlignment="Center"
                                             TextChanged="OnInlineTagInputTextChanged"
                                             KeyDown="OnInlineTagInputKeyDown" />

                                    <Button x:Name="InlineTagAddButton"
                                            Grid.Column="2"
                                            MinWidth="48"
                                            Style="{StaticResource InlineTagButtonStyle}"
                                            Content="添加"
                                            Click="OnInlineTagAddClick" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Expander>

                    <Expander Header="处理机制"
                              IsExpanded="False"
                              Style="{StaticResource InlineSectionExpanderStyle}">
                        <Border Background="#FFE2E8EF"
                                BorderBrush="#FFA9B6C3"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,8,8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="模型" />
                                <ComboBox x:Name="InlineModelCombo" Grid.Row="0" Grid.Column="1" Height="26" Margin="0,0,0,6" Style="{StaticResource InlineComboStyle}" SelectionChanged="OnInlineOptionChanged" DropDownClosed="OnInlineOptionDropDownClosed" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="路由" />
                                <ComboBox x:Name="InlineRouteCombo" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,0,0,0" Style="{StaticResource InlineComboStyle}" SelectionChanged="OnInlineOptionChanged" DropDownClosed="OnInlineOptionDropDownClosed" />
                            </Grid>
                        </Border>
                    </Expander>

                    <Expander Header="存储机制"
                              IsExpanded="False"
                              Style="{StaticResource InlineSectionExpanderStyle}"
                              Margin="0">
                        <Border Background="#FFE2E8EF"
                                BorderBrush="#FFA9B6C3"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,8,8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#FF1F2A36" Text="持久化" />
                                <ComboBox x:Name="InlinePersistenceCombo" Grid.Column="1" Height="26" Margin="0,0,0,0" Style="{StaticResource InlineComboStyle}" SelectionChanged="OnInlineOptionChanged" DropDownClosed="OnInlineOptionDropDownClosed" />
                            </Grid>
                        </Border>
                    </Expander>
                </StackPanel>
            </Border>
        </Border>

         <Popup x:Name="DragGhostPopup"
             Placement="AbsolutePoint"
               AllowsTransparency="True"
               StaysOpen="True"
               IsHitTestVisible="False">
            <Border x:Name="DragGhostBorder"
                    Padding="10,8"
                    CornerRadius="7"
                    Background="#DD243449"
                    BorderBrush="#FFA4C3E5"
                    BorderThickness="1"
                    Opacity="0.95">
                <StackPanel>
                    <TextBlock x:Name="DragGhostTitleText"
                               FontWeight="SemiBold"
                               Foreground="#FFF0F5FB" />
                    <TextBlock x:Name="DragGhostSubtitleText"
                               Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="#FFC8D6E8" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>

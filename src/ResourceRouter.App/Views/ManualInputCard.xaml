<UserControl x:Class="ResourceRouter.App.Views.ManualInputCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="130">
    <UserControl.Resources>
        <Style x:Key="DarkInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1B2430" />
            <Setter Property="Foreground" Value="#FFE6ECF2" />
            <Setter Property="BorderBrush" Value="#FF4E5D71" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="#FFE6ECF2" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="DarkSubmitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2C3A4B" />
            <Setter Property="Foreground" Value="#FFE8EEF5" />
            <Setter Property="BorderBrush" Value="#FF59708B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SubmitBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SubmitBorder" Property="Background" Value="#FF3A4D63" />
                                <Setter TargetName="SubmitBorder" Property="BorderBrush" Value="#FF8AAAD0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SubmitBorder" Property="Background" Value="#FF4B6581" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Margin="8" Padding="8" BorderBrush="#FF354250" BorderThickness="1" CornerRadius="8" Background="#FF171F29">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox x:Name="TitleTextBox" Height="28" VerticalContentAlignment="Center" ToolTip="标题（可选）" Style="{StaticResource DarkInputStyle}" />
            <TextBox x:Name="BodyTextBox" Grid.Row="1" Margin="0,6,0,0" Height="54" AcceptsReturn="True" TextWrapping="Wrap" ToolTip="输入正文" Style="{StaticResource DarkInputStyle}" />
            <Button Grid.Row="2" Margin="0,8,0,0" Height="28" HorizontalAlignment="Right" Padding="12,0" Style="{StaticResource DarkSubmitButtonStyle}" Click="OnSubmitClick">手动添加</Button>
        </Grid>
    </Border>
</UserControl>